# Anthropic API key — required ONLY for live Claude triage (AI_MODE=live) and
# the /api/retriage route. The heuristic engine and the seeded demo work
# without it. Copy this file to .env.local and fill in your key.
ANTHROPIC_API_KEY=

# Which engine the triage CLI uses by default: "heuristic" (no key, free) or
# "live" (real Claude via @anthropic-ai/sdk). CLI flag --mode overrides this.
AI_MODE=heuristic

# Claude model used for live triage.
ANTHROPIC_MODEL=claude-opus-4-8
